{
  "name": "mjh-pubg-royale",
  "version": "1.0.0",
  "private": true,
  "description": "Multiplayer Battle Royale PWA Game with authoritative server",
  "main": "apps/server/index.js",
  "scripts": {
    "dev": "concurrently "npm run web:dev" "npm run server:dev"",
    "web:dev": "serve . -p 3000 --cors",
    "server:dev": "nodemon apps/server/index.js",
    "build": "npm run build:web && npm run build:server",
    "build:web": "echo "Web build ready" && mkdir -p deploy/web",
    "build:server": "echo "Server build ready" && mkdir -p deploy/server",
    "start": "node apps/server/index.js",
    "deploy": "npm run build && echo "Deploy to Vercel/Netlify"",
    "test": "echo "Add tests later" && exit 0",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "keywords": [
    "pwa",
    "multiplayer",
    "battle-royale",
    "game",
    "websocket",
    "node",
    "pubg"
  ],
  "author": "MJ H",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/mjh-pubg-royale"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.3"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "ws": "^8.16.0",
    "cors": "^2.8.5"
  },
  "workspaces": [
    "apps/web",
    "apps/server",
    "packages/*"
  ],
  "packageManager": "npm@9.8.1"
}
